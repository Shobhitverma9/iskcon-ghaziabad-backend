{
  "info": {
    "name": "ISKCON Ghaziabad API",
    "_postman_id": "iskcon-api-collection",
    "description": "Complete API collection for ISKCON Ghaziabad backend. Set the `baseUrl` variable to your Cloud Run URL.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://iskcon-backend-771969643892.asia-south1.run.app",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string",
      "description": "JWT token - set this after login"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.access_token) {",
                  "  pm.collectionVariables.set('token', json.access_token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@iskconghaziabad.com\",\n  \"password\": \"your-password\"\n}"
            }
          }
        },
        {
          "name": "Google Login",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/google",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idToken\": \"GOOGLE_ID_TOKEN_HERE\"\n}"
            }
          }
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/profile"
          }
        }
      ]
    },
    {
      "name": "Banners",
      "item": [
        {
          "name": "Get All Banners",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": "{{baseUrl}}/banners"
          }
        },
        {
          "name": "Get Banner by ID",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": "{{baseUrl}}/banners/BANNER_ID"
          }
        },
        {
          "name": "Create Banner (Admin)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/banners",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title", "value": "Test Banner", "type": "text" },
                { "key": "image", "type": "file", "src": [] }
              ]
            }
          }
        },
        {
          "name": "Update Banner (Admin)",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/banners/BANNER_ID",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Banner\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Delete Banner (Admin)",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/banners/BANNER_ID"
          }
        }
      ]
    },
    {
      "name": "Blog",
      "item": [
        {
          "name": "Get All Blogs",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/blog?page=1&limit=10",
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Get Blog by Slug",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": "{{baseUrl}}/blog/BLOG_SLUG"
          }
        },
        {
          "name": "Create Blog (Admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/blog",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Test Blog\",\n  \"slug\": \"test-blog\",\n  \"content\": {},\n  \"category\": \"General\"\n}"
            }
          }
        },
        {
          "name": "Update Blog (Admin)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/blog/BLOG_ID",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Title\"\n}"
            }
          }
        },
        {
          "name": "Delete Blog (Admin)",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/blog/BLOG_ID"
          }
        }
      ]
    },
    {
      "name": "Pooja",
      "item": [
        {
          "name": "Get All Poojas",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": "{{baseUrl}}/pooja"
