        },
        {
          "name": "Book Pooja",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/pooja/book",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"poojaId\": \"POOJA_ID\",\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"phone\": \"9876543210\",\n  \"date\": \"2026-04-01\",\n  \"gotras\": [\"Kashyap\"]\n}"
            }
          }
        }
      ]
