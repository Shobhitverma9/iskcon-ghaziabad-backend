            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/payment/create-order",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 1000,\n  \"currency\": \"INR\",\n  \"receipt\": \"test_receipt_001\"\n}"
            }
          }
        },
        {
          "name": "Razorpay Webhook",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-razorpay-signature", "value": "WEBHOOK_SIGNATURE" }
            ],
            "url": "{{baseUrl}}/payment/webhook",
            "body": {
              "mode": "raw",
              "raw": "{}"
            }
          }
        }
      ]
    },
